# ============================================
# Moxie Management — Environment Variables
# ============================================
# Copy this to .env.local and fill in your values

# --- Notion Integration ---
NOTION_API_KEY=secret_your_notion_api_key
NOTION_ROADMAP_DB_ID=your_roadmap_database_id
NOTION_INSPECTIONS_DB_ID=your_inspections_database_id
NOTION_MAINTENANCE_DB_ID=your_maintenance_database_id
NOTION_PROPERTIES_DB_ID=your_properties_database_id

# --- AppFolio API ---
APPFOLIO_CLIENT_ID=your_appfolio_client_id
APPFOLIO_CLIENT_SECRET=your_appfolio_client_secret
APPFOLIO_DATABASE_NAME=your_appfolio_subdomain

# --- Supabase (persistent storage for inspections, photos, PDFs) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# --- Anthropic API (Claude Haiku for AI photo analysis) ---
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key
