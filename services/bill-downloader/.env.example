# ============================================
# Moxie Bill Downloader — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file.

# --- Bearer token for API authentication ---
# Generate a long random string. The SAME value must be set in Railway
# as RUBS_DOWNLOADER_TOKEN for the webapp to authenticate with this service.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
RUBS_DOWNLOADER_TOKEN=replace_with_long_random_string

# --- Bills folder ---
# Where downloaded PDFs will be saved. Use the Dropbox folder path
# so files sync automatically.
BILLS_FOLDER=C:\Users\deniz\Simpatico Systems Dropbox\Brad Management\MOXIE MANAGEMENT\AI\RUBs\Utility Bills

# --- LADWP Credentials ---
# Account 1 (primary)
LADWP_USER_1=your_ladwp_email_1@example.com
LADWP_PASSWORD_1=your_ladwp_password_1

# Account 2 (Barrett / secondary)
LADWP_USER_2=your_ladwp_email_2@example.com
LADWP_PASSWORD_2=your_ladwp_password_2

# --- SoCal Gas Credentials ---
# Account 1 (primary)
SOCALGAS_USER_1=your_socalgas_email_1@example.com
SOCALGAS_PASSWORD_1=your_socalgas_password_1

# Account 2 (Dorr Holdings / secondary)
SOCALGAS_USER_2=your_socalgas_email_2@example.com
SOCALGAS_PASSWORD_2=your_socalgas_password_2

# --- Server port ---
# The local port the service listens on. Expose this via ngrok or similar.
PORT=4401

# --- Playwright settings ---
# Set HEADLESS=false to watch the browser run (useful for debugging /
# verifying after recording new flows). Default is headless (invisible).
HEADLESS=true
